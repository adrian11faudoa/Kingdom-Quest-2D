; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters are not all string-only.

config_version=5

[application]

config/name="AetherQuest"
config/description="A top-down 2D action RPG with deep systems and a living world."
config/version="0.1.0"
run/main_scene="res://scenes/ui/menus/MainMenu.tscn"
config/use_custom_user_dir=true
config/custom_user_dir_name="AetherQuest"
config/features=PackedStringArray("4.3", "GL Compatibility")
boot_splash/bg_color=Color(0.05, 0.05, 0.08, 1)
boot_splash/show_image=false
config/icon="res://assets/art/ui/icons/icon.png"

[autoload]

# Core singletons — kept minimal, only truly global state lives here
GameManager="*res://scripts/autoloads/GameManager.gd"
SaveManager="*res://scripts/autoloads/SaveManager.gd"
EventBus="*res://scripts/autoloads/EventBus.gd"
AudioManager="*res://scripts/autoloads/AudioManager.gd"
InputManager="*res://scripts/autoloads/InputManager.gd"
SceneTransition="*res://scripts/autoloads/SceneTransition.gd"
DataManager="*res://scripts/autoloads/DataManager.gd"
ObjectPool="*res://scripts/autoloads/ObjectPool.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/vsync/vsync_mode=1

[rendering]

textures/canvas_textures/default_texture_filter=0  ; Nearest — pixel art
renderer/rendering_method="gl_compatibility"
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true

[physics]

2d/default_gravity=0
2d/physics_engine="GodotPhysics2D"

[layer_names]

2d_physics/layer_1="world"
2d_physics/layer_2="player"
2d_physics/layer_3="enemies"
2d_physics/layer_4="npcs"
2d_physics/layer_5="items"
2d_physics/layer_6="projectiles"
2d_physics/layer_7="interactables"
2d_physics/layer_8="hazards"

