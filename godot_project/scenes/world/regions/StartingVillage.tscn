[gd_scene load_steps=12 format=3 uid="uid://starting_village"]

[ext_resource type="Script" path="res://scripts/systems/daynight/DayNightSystem.gd" id="1"]
[ext_resource type="Script" path="res://scripts/systems/quest/QuestSystem.gd" id="2"]
[ext_resource type="Script" path="res://scripts/systems/dialogue/DialogueSystem.gd" id="3"]
[ext_resource type="Script" path="res://scripts/systems/worldgen/WorldStreamer.gd" id="4"]
[ext_resource type="Script" path="res://scripts/systems/WorldEventSystem.gd" id="5"]
[ext_resource type="Script" path="res://scripts/ui/PauseMenu.gd" id="6"]
[ext_resource type="PackedScene" path="res://scenes/entities/player/Player.tscn" id="7"]
[ext_resource type="PackedScene" path="res://scenes/ui/hud/HUD.tscn" id="8"]
[ext_resource type="PackedScene" path="res://scenes/ui/menus/PauseMenu.tscn" id="9"]

[node name="StartingVillage" type="Node2D"]

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]

[node name="CanvasModulate" type="CanvasModulate" parent="."]
color = Color(1, 1, 1, 1)

[node name="DirectionalLight2D" type="DirectionalLight2D" parent="."]
energy = 0.8
height = 100.0

[node name="DayNightSystem" type="Node" parent="." groups=["daynight"]]
script = ExtResource("1")
seconds_per_hour = 60.0
start_hour = 8.0

[node name="QuestSystem" type="Node" parent="." groups=["quest_system"]]
script = ExtResource("2")

[node name="DialogueSystem" type="Node" parent="."]
script = ExtResource("3")

[node name="WorldStreamer" type="Node" parent="."]
script = ExtResource("4")
chunk_size = Vector2i(32, 32)
tile_size = 16
load_radius = 3
render_radius = 4

[node name="WorldEventSystem" type="Node" parent="."]
script = ExtResource("5")

# ── Tilemap layers ─────────────────────────────────────────────────────────────
[node name="Ground" type="TileMapLayer" parent="."]
tile_set = null
# Assign village_ground.tres TileSet in the editor

[node name="Walls" type="TileMapLayer" parent="."]
tile_set = null
# Assign village_walls.tres TileSet in the editor

[node name="Details" type="TileMapLayer" parent="."]
tile_set = null
z_index = 1

# ── Navigation ─────────────────────────────────────────────────────────────────
[node name="NavigationRegion2D" type="NavigationRegion2D" parent="."]
# Bake navmesh in editor after placing tiles

# ── Entities ──────────────────────────────────────────────────────────────────
[node name="Entities" type="Node2D" parent="."]

[node name="NPCs" type="Node2D" parent="Entities"]

[node name="Enemies" type="Node2D" parent="Entities"]

[node name="Interactables" type="Node2D" parent="Entities"]

# ── Player (spawned at village square) ────────────────────────────────────────
[node name="Player" parent="." instance=ExtResource("7")]
position = Vector2(128, 128)

# ── UI layers ─────────────────────────────────────────────────────────────────
[node name="HUD" parent="." instance=ExtResource("8")]

[node name="PauseMenu" parent="." instance=ExtResource("9")]
